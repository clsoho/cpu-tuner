{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CPU Tuner",
  "version": "0.1.0",
  "identifier": "com.cputuner.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "CPU Tuner",
        "label": "main",
        "width": 1100,
        "height": 750,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.ico"],
    "category": "Utility",
    "shortDescription": "CPU Tuner - Windows CPU 性能调优工具",
    "longDescription": "CPU Tuner 是一个 Windows 桌面工具，用于管理电源计划、调整 CPU 频率参数和监控系统性能。",
    "copyright": "Copyright © 2026 CPU Tuner",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}
